{
    "cmake.sourceDirectory": "${workspaceFolder}",
    "cmake.configureOnOpen": false,
    "cmake.configureOnEdit": false,
    "cmake.automaticReconfigure": false,
    "python.envFile": "${workspaceFolder}/.env",
    "python.testing.pytestArgs": [
        "python/MaterialXTest",
        "contrib/tests",
        "contrib/metashade/tests"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "python.testing.cwd": "${workspaceFolder}",
    "python.analysis.extraPaths": [
        "${workspaceFolder}/build/python",
        "${workspaceFolder}/python",
        "${workspaceFolder}/contrib/metashade"
    ],
    "testMate.cpp.test.executables": "${workspaceFolder}/build/bin/Debug/MaterialXTest.exe",
    "testMate.cpp.test.workingDirectory": "${workspaceFolder}",
    "testMate.cpp.log.logfile": "${workspaceFolder}/build/testmate.log",
    "testMate.cpp.log.logSeverity": "debug",
    "testMate.cpp.debug.configTemplate": {
        "type": "cppvsdbg",
        "request": "launch"
    }
}